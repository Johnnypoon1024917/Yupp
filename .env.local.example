# Browserless.io remote browser service
BROWSERLESS_URL=your-browserless-url

# Google Places API (New) for geocoding
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Custom LLM (highest-priority AI extraction — any OpenAI-compatible endpoint)
CUSTOM_LLM_ENDPOINT=http://localhost:11434/api/generate
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=default

# Google Gemini API (second-tier AI extraction fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API (third-tier AI extraction fallback)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase Cloud Bridge
NEXT_PUBLIC_SUPABASE_URL=your_supabase_api_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_api_key_here

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
